pkgname=wiremix
pkgver=0.11.0
pkgrel=1
pkgdesc="Dual-mode (TUI + agent-native CLI) mixer for PipeWire"
arch=('x86_64' 'aarch64')
url="https://Wiremix.SpacecraftSoftware.org/"
license=('GPL-3.0-or-later')
depends=('pipewire')
makedepends=('rust' 'cargo' 'pkgconf' 'clang' 'texinfo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/Spacecraft-Software/wiremix/archive/refs/tags/v$pkgver.tar.gz")
# Replace with the real checksum at release time:
#   makepkg -g >> PKGBUILD     (or `updpkgsums`)
sha256sums=('SKIP')

prepare() {
	cd "$pkgname-$pkgver"
	export RUSTUP_TOOLCHAIN=stable
	cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
	cd "$pkgname-$pkgver"
	export RUSTUP_TOOLCHAIN=stable
	export CARGO_TARGET_DIR=target
	cargo build --frozen --release --all-features
	make info
}

check() {
	cd "$pkgname-$pkgver"
	export RUSTUP_TOOLCHAIN=stable
	cargo test --frozen --release --all-features
}

package() {
	cd "$pkgname-$pkgver"
	install -Dm0755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
	install -Dm0644 "doc/$pkgname.info" "$pkgdir/usr/share/info/$pkgname.info"
	install -Dm0644 "$pkgname.desktop" \
		"$pkgdir/usr/share/applications/$pkgname.desktop"
	install -Dm0644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
	install -Dm0644 wiremix.toml \
		"$pkgdir/usr/share/doc/$pkgname/wiremix.toml"
}

post_install() {
	install-info /usr/share/info/wiremix.info /usr/share/info/dir 2>/dev/null || true
}

post_upgrade() {
	post_install
}

pre_remove() {
	install-info --delete /usr/share/info/wiremix.info /usr/share/info/dir \
		2>/dev/null || true
}
